# =============================================================================
# Global / shared
# =============================================================================

# Flask runtime
DEBUG=False
USE_RELOADER=False
SECRET_KEY=dev
ENABLE_SCHEDULER=True

# Scheduler / data-crawl window — applies to vndb and imgserve cron jobs.
# SCHEDULER_TIMEZONE: timezone the cron schedules are interpreted in — set it
#   to your user base's timezone so the off-peak window is actually off-peak.
# CRAWL_HOURS: cron hour expression for the off-peak data-crawl window. The
#   vndb/imgserve fetch jobs run hourly, but only within these hours, to keep
#   crawling clear of the VNDB rate limit during user-active times.
SCHEDULER_TIMEZONE=Asia/Shanghai
CRAWL_HOURS=3-6

# Shared data root (per-app subdirectories underneath: images/, backups/, tmp/)
DATA_FOLDER=./DATA


# =============================================================================
# vndb (visual novel data API + remote search proxy)
# =============================================================================

VNDB_HOST=0.0.0.0
VNDB_PORT=5000
VNDB_DB_URL=postgresql://postgres:postgres@localhost:5432/vndb
VNDB_CACHE_REDIS_URL=redis://localhost:6379/0
VNDB_CELERY_DEFAULT_QUEUE=vndb_queue
VNDB_CELERY_BROKER_URL=redis://localhost:6379/1
VNDB_CELERY_RESULT_BACKEND=redis://localhost:6379/2
VNDB_FLOWER_PORT=5556


# =============================================================================
# imgserve (VNDB image cache + edge serving)
# =============================================================================

IMGSERVE_HOST=0.0.0.0
IMGSERVE_PORT=5001
# Waitress worker thread count. Cold image requests block on a t.vndb.org
# fetch; bumping this lets more concurrent misses be in-flight. Combined with
# the Redis single-flight, duplicate requests for the same image only do one
# upstream fetch.
IMGSERVE_WAITRESS_THREADS=64
IMGSERVE_DB_URL=postgresql://postgres:postgres@localhost:5432/imgserve
IMGSERVE_CACHE_REDIS_URL=redis://localhost:6379/3
# Direct redis (single-flight lock + access ZSET). Separate from the cache DB
# so bookkeeping keys don't share the Flask-Caching keyspace.
IMGSERVE_REDIS_URL=redis://localhost:6379/8
IMGSERVE_CELERY_DEFAULT_QUEUE=imgserve_queue
IMGSERVE_CELERY_BROKER_URL=redis://localhost:6379/4
IMGSERVE_CELERY_RESULT_BACKEND=redis://localhost:6379/5
IMGSERVE_FLOWER_PORT=5557


# =============================================================================
# userserve (accounts, auth, marks)
# =============================================================================

USERSERVE_HOST=0.0.0.0
USERSERVE_PORT=5002
# Waitress thread pool. Mail sends are dispatched async (see userserve/mail.py),
# so 16 leaves plenty of headroom for the short JSON routes.
USERSERVE_WAITRESS_THREADS=16
USERSERVE_DB_URL=postgresql://postgres:postgres@localhost:5432/userserve
USERSERVE_RATELIMIT_STORAGE_URI=redis://localhost:6379/6
USERSERVE_REDIS_URL=redis://localhost:6379/7

# Auth cookies — JWT access & refresh tokens live in httpOnly cookies.
# JWT_COOKIE_SECURE must be True in production (HTTPS); keep it False for local
# HTTP. JWT_COOKIE_SAMESITE: Lax (default) | Strict | None.
# CORS_ORIGINS is the comma-separated allowlist for credentialed requests.
JWT_SECRET_KEY=dev
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=30
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax
CORS_ORIGINS=http://localhost,http://localhost:3000

# Mail (SMTP) — for password reset & sign-up verification codes.
# Configure QQ and/or Gmail; with both unset, emails are logged to the console.
# QQ:    MAIL_QQ_PASSWORD is the SMTP authorization code (授权码), not the QQ
#        account password — generate it in QQ Mail > Settings > Account.
# Gmail: MAIL_GMAIL_PASSWORD is an app password (requires 2-step verification).
# MAIL_PROVIDER_ORDER sets which provider is tried first.
MAIL_QQ_USERNAME=
MAIL_QQ_PASSWORD=
MAIL_GMAIL_USERNAME=
MAIL_GMAIL_PASSWORD=
MAIL_PROVIDER_ORDER=qq,gmail
FRONTEND_BASE_URL=http://localhost

# Registration invite gate. When set, new sign-ups must supply this exact code.
# Leave blank to disable the gate (open registration).
INVITATION_CODE=


# =============================================================================
# Caddy unified edge (optional)
# =============================================================================
# When true (and `caddy` is on PATH), run.py launches Caddy on CADDY_BIND with
# path-prefix routing:
#   /imgserve/*  -> Flask imgserve  (with file_server fast path for cache hits)
#   /userserve/* -> Flask userserve
#   /vndb/*      -> Flask vndb
# Point each frontend *_BASE_URL at the Caddy bind + matching prefix (e.g.
# IMGSERVE_BASE_URL=http://localhost:5080/imgserve) to actually use it.
USE_CADDY=false
CADDY_BIND=:5080
