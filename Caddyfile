# ============================================================================
# Standalone edge — this project running alone behind frp.
#
# Single front door (default :30709) for the Next.js frontend and all the Flask
# backends. The routes themselves live in ./Caddyfile.snippet, which is imported
# here *and* by AppGateway when several apps share one port. Define a route once,
# in the snippet; this file only supplies the site block around it.
#
# Started by backend/launch.py (see make_caddy_spec), which also sets the env the
# snippet expands: CADDY_BIND, {VNDB,IMGSERVE,USERSERVE,TRANSSERVE,MUSICSERVE}_PORT,
# NEXT_PORT, IMGSERVE_IMAGE_FOLDER. Skipped entirely when launch.py is given
# --no-caddy, which is how AppGateway boots this project: the gateway owns the
# port, and two Caddies cannot both bind it.
# ============================================================================
{
	# Quieter default access log; Caddy logs every request otherwise.
	auto_https off

	# We drive Caddy purely from this config file and never touch the admin API,
	# so turn it off. Besides trimming noise, this stops Caddy binding
	# 127.0.0.1:2019 — a leftover/second Caddy process holding that port is what
	# produces "listen tcp 127.0.0.1:2019: bind: Only one usage of each socket
	# address ... is normally permitted" on startup.
	admin off
}

{$CADDY_BIND::30709} {
	import Caddyfile.snippet

	# The frontend lives under its basePath, so the bare origin root serves
	# nothing. Standalone, this project *is* the whole site — send the root at it.
	# (In unified mode the gateway's landing page owns `/` instead, which is why
	# this redirect lives here and not in the shared snippet.)
	handle / {
		redir * /visual-novel-database permanent
	}
}
