# Public ingress — Docker variant.
#
# Same routes as everywhere else: ../Caddyfile.snippet, mounted into the container
# alongside this file. Only the upstreams differ, and those come from env — the
# compose file points them at container names instead of loopback ports, and
# IMGSERVE_IMAGE_FOLDER at the cache volume mounted read-only at /srv/images.
{
	auto_https off
}

:30709 {
	import Caddyfile.snippet

	# The frontend lives under its basePath, so the bare root serves nothing.
	handle / {
		redir * /visual-novel-database permanent
	}

	# Anything the snippet did not claim. Without this Caddy answers an empty 200,
	# which looks like a working page.
	handle {
		respond "Not found" 404
	}
}
