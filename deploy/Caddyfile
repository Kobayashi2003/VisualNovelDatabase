# Unified edge — Docker variant.
#
# Same routing as the repo-root Caddyfile, but upstreams are addressed by
# docker-compose SERVICE NAMES (vndb:5000, …) instead of 127.0.0.1:PORT, since
# each service is its own container. The IPv6-loopback workaround the root
# Caddyfile needs on Windows is irrelevant here (Docker DNS returns the
# container's IPv4).
#
#   /vndb/*       -> vndb:5000
#   /imgserve/*   -> imgserve:5001   (file_server fast path on cache hits)
#   /userserve/*  -> userserve:5002
#   /transserve/* -> transserve:5003
#   /musicserve/* -> musicserve:5004
#   everything else (/, /_next/*, …) -> frontend:5010
#
# The imgserve cache volume is mounted read-only at /srv/images so cache hits
# are served straight from disk; misses fall through to the imgserve container.
{
	auto_https off
}

:30709 {
	# ── imgserve ───────────────────────────────────────────────────────────
	handle_path /imgserve/* {
		@cached_img {
			path_regexp imgpath ^/img(/.+\.jpg)$
			file {
				try_files {re.imgpath.1}
				root /srv/images
			}
		}
		handle @cached_img {
			root * /srv/images
			rewrite * {re.imgpath.1}
			header Cache-Control "public, max-age=31536000, immutable"
			file_server
		}

		handle {
			reverse_proxy imgserve:5001 {
				transport http {
					read_timeout 30s
					write_timeout 30s
				}
			}
		}
	}

	# ── userserve ──────────────────────────────────────────────────────────
	handle_path /userserve/* {
		reverse_proxy userserve:5002
	}

	# ── vndb ───────────────────────────────────────────────────────────────
	handle_path /vndb/* {
		reverse_proxy vndb:5000
	}

	# ── transserve ─────────────────────────────────────────────────────────
	handle_path /transserve/* {
		reverse_proxy transserve:5003
	}

	# ── musicserve ─────────────────────────────────────────────────────────
	handle_path /musicserve/* {
		reverse_proxy musicserve:5004
	}

	# ── frontend (Next.js) ─────────────────────────────────────────────────
	handle {
		reverse_proxy frontend:5010
	}
}
