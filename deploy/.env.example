# =============================================================================
# Compose environment — copy to `deploy/.env` and edit the marked values.
#   cp deploy/.env.example deploy/.env
#
# Hosts point at docker-compose SERVICE NAMES (postgres / redis), not localhost.
# These vars are injected into every backend container (env_file) and a few are
# also read by compose itself (POSTGRES_*).
# =============================================================================

# ---- Secrets — CHANGE THESE before exposing the site -------------------------
SECRET_KEY=change-me-to-a-long-random-string
JWT_SECRET_KEY=change-me-to-another-long-random-string

# ---- Postgres service (read by the postgres container + the app DB URLs) -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=postgres

# ---- Flask runtime -----------------------------------------------------------
DEBUG=False
USE_RELOADER=False
ENABLE_SCHEDULER=True

# Data-crawl window (vndb + imgserve cron). Set the timezone to your users' so
# the off-peak window actually lands off-peak; CRAWL_HOURS is a cron hour range.
SCHEDULER_TIMEZONE=Asia/Shanghai
CRAWL_HOURS=3-6

# Shared data root inside the containers (mounted from the `appdata` volume).
DATA_FOLDER=/data

# =============================================================================
# vndb (visual novel data API + remote search proxy)
# =============================================================================
VNDB_HOST=0.0.0.0
VNDB_PORT=5000
VNDB_DB_URL=postgresql://postgres:postgres@postgres:5432/vndb
VNDB_CACHE_REDIS_URL=redis://redis:6379/0
VNDB_CELERY_DEFAULT_QUEUE=vndb_queue
VNDB_CELERY_BROKER_URL=redis://redis:6379/1
VNDB_CELERY_RESULT_BACKEND=redis://redis:6379/2
VNDB_FLOWER_PORT=5556

# =============================================================================
# imgserve (VNDB image cache + edge serving)
# =============================================================================
IMGSERVE_HOST=0.0.0.0
IMGSERVE_PORT=5001
IMGSERVE_WAITRESS_THREADS=64
IMGSERVE_DB_URL=postgresql://postgres:postgres@postgres:5432/imgserve
IMGSERVE_CACHE_REDIS_URL=redis://redis:6379/3
IMGSERVE_REDIS_URL=redis://redis:6379/8
IMGSERVE_CELERY_DEFAULT_QUEUE=imgserve_queue
IMGSERVE_CELERY_BROKER_URL=redis://redis:6379/4
IMGSERVE_CELERY_RESULT_BACKEND=redis://redis:6379/5
IMGSERVE_FLOWER_PORT=5557

# =============================================================================
# userserve (accounts, auth, marks)
# =============================================================================
USERSERVE_HOST=0.0.0.0
USERSERVE_PORT=5002
USERSERVE_WAITRESS_THREADS=16
USERSERVE_DB_URL=postgresql://postgres:postgres@postgres:5432/userserve
USERSERVE_RATELIMIT_STORAGE_URI=redis://redis:6379/6
USERSERVE_REDIS_URL=redis://redis:6379/7

# Auth cookies. JWT_COOKIE_SECURE must stay False for plain-HTTP access (e.g.
# http://localhost:30709); set it True only when serving the edge over HTTPS.
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=30
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax
CORS_ORIGINS=http://localhost:30709

# Mail (SMTP) — for password reset & sign-up codes. Left blank: emails are
# logged to the container console (fine for a private/demo instance).
MAIL_QQ_USERNAME=
MAIL_QQ_PASSWORD=
MAIL_GMAIL_USERNAME=
MAIL_GMAIL_PASSWORD=
MAIL_PROVIDER_ORDER=qq,gmail
FRONTEND_BASE_URL=http://localhost:30709

# Registration invite gate. Blank = open registration. Set a code to require it.
INVITATION_CODE=

# =============================================================================
# transserve (translation service: en->ja dictionary + passage TM)
# =============================================================================
TRANSSERVE_HOST=0.0.0.0
TRANSSERVE_PORT=5003
TRANSSERVE_DB_URL=postgresql://postgres:postgres@postgres:5432/transserve
TRANSSERVE_WAITRESS_THREADS=8
TRANSSERVE_SOURCE_LANG=en
TRANSSERVE_TARGET_LANG=ja

# =============================================================================
# musicserve (VN theme-music file service)
# =============================================================================
MUSICSERVE_HOST=0.0.0.0
MUSICSERVE_PORT=5004
# User-supplied music library, bind-mounted at /music (see docker-compose.yml).
MUSICSERVE_MUSIC_FOLDER=/music
MUSICSERVE_WAITRESS_THREADS=16

# =============================================================================
# Caddy edge — runs as its own container here, NOT via launch.py.
# =============================================================================
USE_CADDY=false
