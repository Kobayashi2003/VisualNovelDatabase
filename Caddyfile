# Standalone edge — this project alone behind frp on :30709.
#
# Routes live in ./Caddyfile.snippet; this file is just the site block around
# them. Started by start-prod.ps1, which sets the upstream env vars from
# caddy-env.ps1. Skipped under `start-prod.ps1 -NoCaddy`, when AppGateway owns the
# port instead.
{
	auto_https off

	# Never used, and leaving it on binds 127.0.0.1:2019 — which collides with any
	# second Caddy on the box.
	admin off
}

{$CADDY_BIND::30709} {
	import Caddyfile.snippet

	# The frontend lives under its basePath, so the bare root serves nothing.
	# Standalone, this project is the whole site. (Under AppGateway the root is
	# the landing page — hence this lives here, not in the snippet.)
	handle / {
		redir * /visual-novel-database permanent
	}

	# Anything the snippet did not claim. Without this Caddy answers an empty 200,
	# which looks like a working page. (Under AppGateway the catch-all is the
	# landing page instead — which is why it lives here, not in the snippet.)
	handle {
		respond "Not found" 404
	}
}
