# Backend unified edge.
#
# What it does:
#   - Single front door (default :5080) for all three Flask backends. Path
#     prefix decides where the request goes:
#       /imgserve/*  -> imgserve  (with the file_server fast path below)
#       /userserve/* -> userserve
#       /vndb/*      -> vndb
#     `handle_path` strips the matched prefix before forwarding, so each
#     backend keeps its existing route shape (it sees /img/..., /login,
#     /v123, etc. — not the prefixed form).
#   - For /imgserve/img/<type>/<dir>/<id>.jpg requests where the file
#     already lives under IMAGE_FOLDER, serve directly from disk with an
#     immutable Cache-Control header. Flask is never hit.
#   - Everything else is reverse-proxied to the matching Flask app, which
#     runs the Redis single-flight fetch+store path on imgserve misses.
#
# Env vars (set by backend/run.py when launching caddy):
#   CADDY_BIND            - bind address, e.g. ":5080"
#   IMGSERVE_PORT         - Flask imgserve port,  e.g. 5001
#   USERSERVE_PORT        - Flask userserve port, e.g. 5002
#   VNDB_PORT             - Flask vndb port,      e.g. 5000
#   IMGSERVE_IMAGE_FOLDER - absolute path to the imgserve image cache root
#                           (disk layout mirrors the URL minus the /imgserve
#                            edge prefix and the /img app prefix; for
#                            example /imgserve/img/cv/87/9087.jpg ->
#                            IMAGE_FOLDER/cv/87/9087.jpg).
{
	# Quieter default access log; Caddy logs every request otherwise.
	auto_https off
}

{$CADDY_BIND::5080} {
	# ── imgserve ───────────────────────────────────────────────────────────
	# handle_path strips /imgserve before the inner matchers see the path,
	# so the regex below matches against /img/<type>/<dir>/<id>.jpg — the
	# same shape Flask routes on directly.
	handle_path /imgserve/* {
		# Fast path: URL maps directly to an existing file under IMAGE_FOLDER.
		# The file matcher checks existence using try_files relative to root;
		# if missing, the named matcher fails and we fall through to the
		# reverse_proxy below.
		@cached_img {
			path_regexp imgpath ^/img(/.+\.jpg)$
			file {
				try_files {re.imgpath.1}
				root {$IMGSERVE_IMAGE_FOLDER}
			}
		}
		handle @cached_img {
			root * {$IMGSERVE_IMAGE_FOLDER}
			rewrite * {re.imgpath.1}
			header Cache-Control "public, max-age=31536000, immutable"
			file_server
		}

		# Cache miss + every non-cacheable verb / route falls here.
		handle {
			reverse_proxy localhost:{$IMGSERVE_PORT} {
				# Long header timeout because cold image fetches can take a
				# few seconds while the single-flight worker pulls from
				# t.vndb.org.
				transport http {
					read_timeout 30s
					write_timeout 30s
				}
			}
		}
	}

	# ── userserve ──────────────────────────────────────────────────────────
	handle_path /userserve/* {
		reverse_proxy localhost:{$USERSERVE_PORT}
	}

	# ── vndb ───────────────────────────────────────────────────────────────
	handle_path /vndb/* {
		reverse_proxy localhost:{$VNDB_PORT}
	}

	# Anything not matched above is a client mistake.
	handle {
		respond "Not Found — use /imgserve/*, /userserve/*, or /vndb/*" 404
	}
}
